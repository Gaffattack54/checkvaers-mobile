# Public URL for the prepared, gzipped VAERS JSON snapshot.
#
# When UNSET, the app uses the 50-record sample dataset bundled in
# lib/vaers/mock-data.ts — useful for development.
#
# When SET, the app fetches the file once on first launch, decompresses
# it client-side, and caches it in IndexedDB. Subsequent loads check the
# ETag and only re-download when the upstream file changes.
#
# To generate the snapshot:
#   1. Download year ZIPs from https://vaers.hhs.gov/data/datasets.html
#      and extract them into ./vaers-raw/
#   2. Run: npm run prepare:vaers
#   3. Upload ./dist/vaers-covid-7yr.json.gz to your hosting target
#      (Cloudflare R2 public bucket OR GitHub Release asset on this repo)
#   4. Set NEXT_PUBLIC_VAERS_DATA_URL to its public URL below.
#
# NEXT_PUBLIC_VAERS_DATA_URL=https://example.com/vaers-covid-7yr.json.gz

# Optional: Plausible analytics domain (privacy-respecting). Leave unset
# to keep analytics disabled entirely (the default).
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
