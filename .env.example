# Public URL for the prepared, gzipped VAERS JSON snapshot.
# Hosted on Cloudflare R2 (public bucket) or as a GitHub Release asset.
# Generated by `npm run prepare-vaers-data`.
NEXT_PUBLIC_VAERS_DATA_URL=https://example.com/vaers-covid-7yr.json.gz

# Optional: enable Plausible analytics (privacy-respecting, off by default).
# Leave unset to disable.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
